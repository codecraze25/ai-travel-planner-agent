# =============================================================================
# Host-local (default — no Docker)
# =============================================================================
APP_ENV=local
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=8010
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=sqlite+aiosqlite:///./data/travel.db
REDIS_URL=
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/uploads

AUTH_DISABLED=true
DEV_USER_ID=dev-user
DEV_USER_EMAIL=demo@example.com
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8010

USE_MOCK_PROVIDERS=true
USE_MOCK_LLM=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o-mini

# =============================================================================
# Docker Compose overrides (set automatically by docker-compose.yml)
# =============================================================================
# DATABASE_URL=postgresql+asyncpg://travel:travel@postgres:5432/travel_planner
# REDIS_URL=redis://redis:6379/0
# STORAGE_BACKEND=s3
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=travel-docs
# S3_REGION=us-east-1

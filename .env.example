# App
APP_ENV=local
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://travel:travel@postgres:5432/travel_planner

# Redis
REDIS_URL=redis://redis:6379/0

# Object storage (MinIO / S3)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=travel-docs
S3_REGION=us-east-1

# Auth (Phase 1)
AUTH_DISABLED=true
DEV_USER_ID=dev-user
DEV_USER_EMAIL=demo@example.com
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# AI (Phase 4)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o-mini

# Travel APIs (Phase 2) — mock providers used when true
USE_MOCK_PROVIDERS=true
DUFFEL_API_TOKEN=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Observability (optional in local)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Email (Phase 6)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
